---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

// Get all blog posts
const blog = await getCollection('blog');

// Filter out drafts and sort by date (newest first)
const posts = blog
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group posts by year for better UX
const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(postsByYear).sort().reverse();
---

<PageLayout 
  title="Blog" 
  description="DevOps insights, infrastructure learnings, and technical deep-dives from Ayodeji Bamidele"
>
  <section class="blog-container">
    <header class="blog-header">
      <h1>Blog & Articles</h1>
      <p class="subtitle">
        Sharing DevOps learnings, infrastructure insights, and technical deep-dives
      </p>
    </header>

    {years.length === 0 ? (
      <div class="no-posts">
        <p>No blog posts yet. Check back soon! 📝</p>
      </div>
    ) : (
      <div class="posts-by-year">
        {years.map(year => (
          <section class="year-section">
            <h2 class="year-heading">{year}</h2>
            <div class="posts-grid">
              {postsByYear[year].map(post => (
                <article class="post-card">
                  <div class="post-content">
                    <h3>
                      <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                    </h3>
                    
                    <p class="description">{post.data.description}</p>
                    
                    <div class="post-meta">
                      <span class="date">
                        {post.data.pubDate.toLocaleDateString('en-US', {
                          month: 'short',
                          day: 'numeric',
                        })}
                      </span>
                    </div>
                    
                    {post.data.tags.length > 0 && (
                      <div class="tags">
                        {post.data.tags.map(tag => (
                          <span class="tag">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                    
                    <a href={`/blog/${post.slug}`} class="read-more">
                      Read article →
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </section>
</PageLayout>

<style lang="scss">
  @import "../../assets/css/_utils.scss";

  .blog-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1rem;

    @include mobile {
      padding: 2rem 1rem;
    }
  }

  .blog-header {
    text-align: center;
    margin-bottom: 3rem;

    h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
      font-family: var(--font-bold);

      @include mobile {
        font-size: 2rem;
      }
    }

    .subtitle {
      font-size: 1.2rem;
      color: #666;
      line-height: 1.6;
    }
  }

  .no-posts {
    text-align: center;
    padding: 3rem;
    color: #999;
    font-size: 1.1rem;
  }

  .posts-by-year {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .year-section {
    .year-heading {
      font-size: 1.5rem;
      color: var(--primary);
      margin-bottom: 2rem;
      font-family: var(--font-medium);
      border-bottom: 2px solid rgba(25, 21, 69, 0.1);
      padding-bottom: 1rem;
    }
  }

  .posts-grid {
    display: grid;
    gap: 2rem;
  }

  .post-card {
    border: 1px solid rgba(213, 213, 213, 0.3);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    background: #fff;
    display: flex;
    flex-direction: column;

    &:hover {
      border-color: rgba(213, 213, 213, 0.6);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
      transform: translateY(-4px);
    }

    .post-content {
      padding: 1.5rem;
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }

    h3 {
      font-size: 1.5rem;
      margin: 0 0 0.75rem 0;
      font-family: var(--font-semi-bold);
      line-height: 1.4;

      a {
        color: var(--primary);
        text-decoration: none;
        transition: color 0.3s ease;

        &:hover {
          color: rgba(25, 21, 69, 0.7);
          text-decoration: underline;
        }
      }
    }

    .description {
      color: #666;
      font-size: 0.95rem;
      line-height: 1.6;
      margin: 0 0 1rem 0;
      flex-grow: 1;
    }

    .post-meta {
      display: flex;
      gap: 1.5rem;
      align-items: center;
      margin: 1rem 0;
      font-size: 0.85rem;
      color: #888;
      flex-wrap: wrap;

      .date {
        font-weight: 500;
      }
    }

    .tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin: 0.75rem 0;

      .tag {
        background: rgba(25, 21, 69, 0.08);
        color: var(--primary);
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
      }
    }

    .read-more {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      margin-top: 1rem;
      transition: all 0.3s ease;
      width: fit-content;

      &:hover {
        text-decoration: underline;
        transform: translateX(4px);
      }
    }
  }
</style>
